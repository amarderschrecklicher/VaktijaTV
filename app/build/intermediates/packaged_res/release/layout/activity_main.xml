<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- ===== SCREEN 0: MAIN SLIDESHOW ===== -->
    <FrameLayout
        android:id="@+id/screen_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <!-- Background gradient overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient" />

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:padding="32dp">

            <!-- Location -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="start|center_vertical">

                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SARAJEVO"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>

            <!-- Date center -->
            <TextView
                android:id="@+id/tv_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="ponedjeljak, 2. mart 2026."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.05" />

            <!-- Settings button -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end|center_vertical">

                <View
                    android:id="@+id/btn_settings"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_settings_btn"
                    android:focusable="true"
                    android:clickable="true" />
            </LinearLayout>
        </LinearLayout>

        <!-- Center: Clock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <TextView
                android:id="@+id/tv_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00:00"
                android:textColor="@color/text_primary"
                android:textSize="96sp"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="-0.03"
                android:layout_marginBottom="32dp" />

            <!-- Divider line -->
            <View
                android:layout_width="48dp"
                android:layout_height="1dp"
                android:background="@color/accent_gold"
                android:layout_marginBottom="32dp" />

            <!-- Slide content -->
            <TextView
                android:id="@+id/tv_slide_text"
                android:layout_width="600dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_slide_subtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="@color/accent_gold"
                android:textSize="13sp"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="0.1" />
        </LinearLayout>

    </FrameLayout>

    <!-- ===== SCREEN 1: PRAYER TIMES ===== -->
    <FrameLayout
        android:id="@+id/screen_prayer_times"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="48dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_prayer_city"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SARAJEVO"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-thin"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/tv_prayer_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ponedjeljak, 2. mart 2026."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tv_clock_prayer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12:00:00"
                        android:textColor="@color/text_primary"
                        android:textSize="48sp"
                        android:fontFamily="sans-serif-thin" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tv_next_prayer_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sljedeći: Akšam"
                            android:textColor="@color/accent_gold"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  ·  "
                            android:textColor="@color/text_tertiary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_next_prayer_countdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45 min"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="24dp" />

            <!-- Prayer times grid - 3 columns x 2 rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Sabah -->
                <LinearLayout
                    android:id="@+id/card_sabah"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_prayer_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SABAH"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_prayer_sabah"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="40sp"
                        android:fontFamily="sans-serif-thin" />
                </LinearLayout>

                <!-- Šuruk -->
                <LinearLayout
                    android:id="@+id/card_suruk"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_prayer_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ŠURUK"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_prayer_suruk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_secondary"
                        android:textSize="40sp"
                        android:fontFamily="sans-serif-thin" />
                </LinearLayout>

                <!-- Podne -->
                <LinearLayout
                    android:id="@+id/card_podne"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_prayer_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PODNE"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_prayer_podne"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="40sp"
                        android:fontFamily="sans-serif-thin" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Ikindija -->
                <LinearLayout
                    android:id="@+id/card_ikindija"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_prayer_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IKINDIJA"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_prayer_ikindija"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="40sp"
                        android:fontFamily="sans-serif-thin" />
                </LinearLayout>

                <!-- Akšam -->
                <LinearLayout
                    android:id="@+id/card_aksam"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_prayer_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AKŠAM"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_prayer_aksam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="40sp"
                        android:fontFamily="sans-serif-thin" />
                </LinearLayout>

                <!-- Jacija -->
                <LinearLayout
                    android:id="@+id/card_jacija"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_margin="8dp"
                    android:background="@drawable/bg_prayer_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JACIJA"
                        android:textColor="@color/text_tertiary"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-light"
                        android:letterSpacing="0.2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_prayer_jacija"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="40sp"
                        android:fontFamily="sans-serif-thin" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

    <!-- ===== SCREEN 2: JUMMAH ===== -->
    <FrameLayout
        android:id="@+id/screen_jummah"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_jummah" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="64dp">

            <!-- Jummah label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الجمعة"
                android:textColor="@color/accent_gold"
                android:textSize="56sp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DŽUMA"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="0.4"
                android:layout_marginBottom="24dp" />

            <TextView
                android:id="@+id/tv_jummah_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Podne — 12:53"
                android:textColor="@color/text_primary"
                android:textSize="64sp"
                android:fontFamily="sans-serif-thin"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_jummah_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45 min do džume"
                android:textColor="@color/accent_gold"
                android:textSize="15sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="40dp" />

            <!-- Divider -->
            <View
                android:layout_width="80dp"
                android:layout_height="1dp"
                android:background="@color/accent_gold_dim"
                android:layout_marginBottom="32dp" />

            <!-- Jummah Ayet -->
            <TextView
                android:id="@+id/tv_jummah_ayet"
                android:layout_width="700dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="17sp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.7" />

            <!-- Clock -->
            <TextView
                android:id="@+id/tv_clock_jummah"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:00:00"
                android:textColor="@color/text_tertiary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-thin"
                android:layout_marginTop="32dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- ===== SCREEN 3: AZAN WARNING ===== -->
    <FrameLayout
        android:id="@+id/screen_azan"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_azan" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="64dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="أَذَان"
                android:textColor="@color/accent_gold"
                android:textSize="72sp"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EZAN"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-thin"
                android:letterSpacing="0.5"
                android:layout_marginBottom="32dp" />

            <TextView
                android:id="@+id/tv_azan_prayer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Akšam"
                android:textColor="@color/text_primary"
                android:textSize="56sp"
                android:fontFamily="sans-serif-thin"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ezan počinje za"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_azan_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="120s"
                android:textColor="@color/accent_gold"
                android:textSize="48sp"
                android:fontFamily="sans-serif-thin"
                android:layout_marginBottom="48dp" />

            <!-- Cancel button -->
            <View
                android:id="@+id/btn_cancel_azan"
                android:layout_width="320dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_cancel_btn"
                android:focusable="true"
                android:clickable="true" />

            <TextView
                android:id="@+id/tv_btn_cancel_text"
                android:layout_width="320dp"
                android:layout_height="64dp"
                android:gravity="center"
                android:text="Otkazati automatski ezan\n(Muezzin će dati ezan)"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-light"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginTop="-64dp"
                android:clickable="false" />

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
